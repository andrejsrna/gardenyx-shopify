{% liquid
  assign active_locale = request.locale.iso_code | default: localization.language.iso_code | downcase
  assign content_locale = 'en'

  if active_locale contains 'hu'
    assign content_locale = 'hu'
  elsif active_locale contains 'sk' or active_locale contains 'cs'
    assign content_locale = 'sk'
  endif

  assign show_fallback_notice = true

  if content_locale == 'en' and active_locale contains 'en'
    assign show_fallback_notice = false
  elsif content_locale == 'hu' and active_locale contains 'hu'
    assign show_fallback_notice = false
  elsif content_locale == 'sk' and active_locale contains 'sk'
    assign show_fallback_notice = false
  endif

%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section page-width-content color-{{ section.settings.color_scheme }}">
  <div
    id="TermsPrivacy-{{ section.id }}"
    class="terms-privacy spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
    data-default-tab="shop"
  >
    <div class="terms-privacy__intro">
      <p class="terms-privacy__eyebrow">{{ 'terms_privacy.eyebrow' | t }}</p>
      <h1 class="terms-privacy__heading">{{ 'terms_privacy.heading' | t }}</h1>
      <p class="terms-privacy__description">{{ 'terms_privacy.description' | t }}</p>
    </div>

    <div class="terms-privacy__tabs" role="tablist" aria-label="{{ 'terms_privacy.tablist_label' | t }}">
      <button
        id="TermsPrivacyTab-shop-{{ section.id }}"
        class="terms-privacy__tab is-active"
        type="button"
        role="tab"
        aria-selected="true"
        aria-controls="TermsPrivacyPanel-shop-{{ section.id }}"
        data-terms-tab="shop"
      >
        {{ 'terms_privacy.shop_tab' | t }}
      </button>
      <button
        id="TermsPrivacyTab-app-{{ section.id }}"
        class="terms-privacy__tab"
        type="button"
        role="tab"
        aria-selected="false"
        aria-controls="TermsPrivacyPanel-app-{{ section.id }}"
        data-terms-tab="app"
      >
        {{ 'terms_privacy.app_tab' | t }}
      </button>
    </div>

    {% if show_fallback_notice %}
      <p class="terms-privacy__notice">{{ 'terms_privacy.fallback_notice' | t }}</p>
    {% endif %}

    <section
      id="TermsPrivacyPanel-shop-{{ section.id }}"
      class="terms-privacy__panel"
      role="tabpanel"
      aria-labelledby="TermsPrivacyTab-shop-{{ section.id }}"
      data-terms-panel="shop"
    >
      <div class="terms-privacy__documents">
        <article class="terms-privacy__document">
          <p class="terms-privacy__document-label">{{ 'terms_privacy.shop_terms_title' | t }}</p>
          <div class="terms-privacy__document-body rte">
            {% if content_locale == 'hu' %}
              {% render 'terms_privacy_hu_shop_terms' %}
            {% elsif content_locale == 'sk' %}
              {% render 'terms_privacy_sk_shop_terms' %}
            {% else %}
              {% render 'terms_privacy_en_shop_terms' %}
            {% endif %}
          </div>
        </article>
        <article class="terms-privacy__document">
          <p class="terms-privacy__document-label">{{ 'terms_privacy.shop_privacy_title' | t }}</p>
          <div class="terms-privacy__document-body rte">
            {% if content_locale == 'hu' %}
              {% render 'terms_privacy_hu_shop_privacy' %}
            {% elsif content_locale == 'sk' %}
              {% render 'terms_privacy_sk_shop_privacy' %}
            {% else %}
              {% render 'terms_privacy_en_shop_privacy' %}
            {% endif %}
          </div>
        </article>
      </div>
    </section>

    <section
      id="TermsPrivacyPanel-app-{{ section.id }}"
      class="terms-privacy__panel"
      role="tabpanel"
      aria-labelledby="TermsPrivacyTab-app-{{ section.id }}"
      data-terms-panel="app"
      hidden
    >
      <div class="terms-privacy__documents">
        <article class="terms-privacy__document">
          <p class="terms-privacy__document-label">{{ 'terms_privacy.app_terms_title' | t }}</p>
          <div class="terms-privacy__document-body rte">
            {% if content_locale == 'hu' %}
              {% render 'terms_privacy_hu_app_terms' %}
            {% elsif content_locale == 'sk' %}
              {% render 'terms_privacy_sk_app_terms' %}
            {% else %}
              {% render 'terms_privacy_en_app_terms' %}
            {% endif %}
          </div>
        </article>
        <article class="terms-privacy__document">
          <p class="terms-privacy__document-label">{{ 'terms_privacy.app_privacy_title' | t }}</p>
          <div class="terms-privacy__document-body rte">
            {% if content_locale == 'hu' %}
              {% render 'terms_privacy_hu_app_privacy' %}
            {% elsif content_locale == 'sk' %}
              {% render 'terms_privacy_sk_app_privacy' %}
            {% else %}
              {% render 'terms_privacy_en_app_privacy' %}
            {% endif %}
          </div>
        </article>
      </div>
    </section>
  </div>
</div>

<script>
  (() => {
    const root = document.getElementById('TermsPrivacy-{{ section.id }}');
    if (!root) return;

    const buttons = Array.from(root.querySelectorAll('[data-terms-tab]'));
    const panels = Array.from(root.querySelectorAll('[data-terms-panel]'));

    const activate = (tab) => {
      buttons.forEach((button) => {
        const isActive = button.dataset.termsTab === tab;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', String(isActive));
        button.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.termsPanel !== tab;
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => activate(button.dataset.termsTab));
    });

    activate(root.dataset.defaultTab || 'shop');
  })();
</script>

{% stylesheet %}
  .terms-privacy {
    display: grid;
    gap: 1.5rem;
  }

  .terms-privacy__intro {
    display: grid;
    gap: 0.75rem;
    max-width: 52rem;
  }

  .terms-privacy__eyebrow {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground-muted);
  }

  .terms-privacy__heading,
  .terms-privacy__description,
  .terms-privacy__document-label {
    margin: 0;
  }

  .terms-privacy__description,
  .terms-privacy__notice {
    color: var(--color-foreground-muted);
  }

  .terms-privacy__notice {
    margin: 0;
  }

  .terms-privacy__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .terms-privacy__tab {
    cursor: pointer;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-foreground);
    padding: 0.8rem 1.1rem;
    font: inherit;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .terms-privacy__tab.is-active {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .terms-privacy__documents {
    display: grid;
    gap: 1rem;

    @media screen and (min-width: 990px) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .terms-privacy__panel[hidden] {
    display: none !important;
  }

  .terms-privacy__document {
    display: grid;
    gap: 1rem;
    padding: clamp(1.25rem, 2vw, 1.75rem);
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
  }

  .terms-privacy__document-label {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground-muted);
  }

  .terms-privacy__document-body {
    font-size: 0.97rem;
    line-height: 1.65;
    overflow-wrap: anywhere;
  }

  .terms-privacy__document-body > :first-child {
    margin-top: 0;
  }

  .terms-privacy__document-body > :last-child {
    margin-bottom: 0;
  }

  .terms-privacy__document-body p,
  .terms-privacy__document-body ul,
  .terms-privacy__document-body ol {
    margin: 0 0 0.85rem;
  }

  .terms-privacy__document-body ul,
  .terms-privacy__document-body ol {
    padding-left: 1.2rem;
  }

  .terms-privacy__document-body li + li {
    margin-top: 0.45rem;
  }

  .terms-privacy__document-body > p:nth-child(-n + 4) {
    text-align: center;
  }

  .terms-privacy__document-body > p:nth-child(1) {
    color: var(--color-foreground-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .terms-privacy__document-body > p:nth-child(2) {
    font-size: 1.2rem;
  }

  .terms-privacy__document-body > p:nth-child(3),
  .terms-privacy__document-body > p:nth-child(4) {
    color: var(--color-foreground-muted);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Terms & Privacy",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    }
  ]
}
{% endschema %}
