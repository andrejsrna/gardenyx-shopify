{% liquid
  assign fallback_mockup_url = 'https://cdn.shopify.com/s/files/1/0969/4124/4803/files/WhatsApp_Image_2026-03-11_at_16.33.34.jpg?v=1773246897'
  assign app_store_badge_url = 'https://cdn.shopify.com/s/files/1/0969/4124/4803/files/Download_on_the_App_Store_Badge.svg?v=1773308827'
  assign google_play_badge_url = 'https://cdn.shopify.com/s/files/1/0969/4124/4803/files/GetItOnGooglePlay_Badge_Web_color_English.svg?v=1773308894'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} app-download-widget color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="app-download-widget__shell">
    <div class="app-download-widget__content">
      <p class="app-download-widget__eyebrow">{{ 'app_download_widget.eyebrow' | t }}</p>
      <h2 class="app-download-widget__heading">{{ 'app_download_widget.heading' | t }}</h2>
      <p class="app-download-widget__description">{{ 'app_download_widget.description' | t }}</p>

      <div class="app-download-widget__actions">
        {% if section.settings.app_store_url != blank %}
          <a href="{{ section.settings.app_store_url }}" class="app-download-widget__badge-link" target="_blank" rel="noopener">
            <img src="{{ app_store_badge_url }}" alt="{{ 'app_download_widget.app_store_label' | t | escape }}" class="app-download-widget__badge" loading="lazy">
          </a>
        {% else %}
          <span class="app-download-widget__badge-link" aria-disabled="true">
            <img src="{{ app_store_badge_url }}" alt="{{ 'app_download_widget.app_store_label' | t | escape }}" class="app-download-widget__badge" loading="lazy">
          </span>
        {% endif %}

        {% if section.settings.google_play_url != blank %}
          <a href="{{ section.settings.google_play_url }}" class="app-download-widget__badge-link" target="_blank" rel="noopener">
            <img src="{{ google_play_badge_url }}" alt="{{ 'app_download_widget.google_play_label' | t | escape }}" class="app-download-widget__badge" loading="lazy">
          </a>
        {% else %}
          <span class="app-download-widget__badge-link" aria-disabled="true">
            <img src="{{ google_play_badge_url }}" alt="{{ 'app_download_widget.google_play_label' | t | escape }}" class="app-download-widget__badge" loading="lazy">
          </span>
        {% endif %}
      </div>
    </div>

    <div class="app-download-widget__image-wrap">
      {% if section.settings.mockup_image != blank %}
        {{
          section.settings.mockup_image
          | image_url: width: 1400
          | image_tag:
            widths: '480, 720, 960, 1200, 1400',
            sizes: '(min-width: 990px) 42vw, 100vw',
            class: 'app-download-widget__image',
            alt: section.settings.mockup_image.alt
        }}
      {% else %}
        <img
          src="{{ section.settings.mockup_image_url | default: fallback_mockup_url }}"
          alt="{{ 'app_download_widget.heading' | t | escape }}"
          class="app-download-widget__image"
          loading="lazy"
        >
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .app-download-widget {
    position: relative;
  }

  .app-download-widget__shell {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 2rem;
    align-items: center;
    padding: clamp(1.5rem, 2vw, 2rem);
    border: 1px solid rgb(var(--color-border-rgb) / 0.8);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgb(126 181 71 / 0.18), transparent 28%),
      radial-gradient(circle at bottom right, rgb(242 176 57 / 0.18), transparent 24%),
      linear-gradient(145deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 0.88));
    box-shadow: 0 24px 80px rgb(19 31 15 / 0.08);
  }

  @media screen and (min-width: 990px) {
    .app-download-widget__shell {
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      padding: clamp(2rem, 4vw, 3.5rem);
    }
  }

  .app-download-widget__content {
    display: grid;
    gap: 1rem;
    max-width: 40rem;
  }

  .app-download-widget__eyebrow {
    margin: 0;
    color: var(--color-foreground-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
  }

  .app-download-widget__heading {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 5vw, 3.9rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .app-download-widget__description {
    margin: 0;
    max-width: 46ch;
    color: var(--color-foreground-muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .app-download-widget__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }

  .app-download-widget__badge-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .app-download-widget__badge-link[aria-disabled='true'] {
    opacity: 0.72;
  }

  .app-download-widget__badge {
    display: block;
    width: auto;
    height: 3.5rem;
  }

  .app-download-widget__image-wrap {
    position: relative;
    display: block;
    border-radius: 1.6rem;
    overflow: hidden;
    box-shadow: 0 24px 70px rgb(18 28 13 / 0.16);
  }

  .app-download-widget__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .app-download-widget__image-wrap {
      border-radius: 1.2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "App download widget",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "url",
      "id": "app_store_url",
      "label": "App Store URL"
    },
    {
      "type": "url",
      "id": "google_play_url",
      "label": "Google Play URL"
    },
    {
      "type": "image_picker",
      "id": "mockup_image",
      "label": "Phone mockup image"
    },
    {
      "type": "url",
      "id": "mockup_image_url",
      "label": "External mockup image URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "App download widget",
      "category": "Text"
    }
  ]
}
{% endschema %}
