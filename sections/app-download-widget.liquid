{% liquid
  assign fallback_mockup_url = 'https://cdn.shopify.com/s/files/1/0969/4124/4803/files/WhatsApp_Image_2026-03-11_at_16.33.34.jpg?v=1773246897'
%}

{% capture apple_icon %}
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path
      d="M15.08 4.03c.82-1 1.37-2.38 1.22-3.76-1.19.05-2.63.8-3.48 1.8-.76.88-1.43 2.28-1.25 3.62 1.32.1 2.66-.67 3.51-1.66Zm1.2 2.01c-1.92 0-2.73 1.15-4.06 1.15-1.37 0-1.73-1.08-3.79-1.08-2.03 0-4.19 1.74-4.19 5.02 0 2.18.86 4.54 1.91 6.03.9 1.27 1.68 2.68 2.96 2.63 1.23-.05 1.7-.79 3.19-.79 1.5 0 1.92.79 3.21.76 1.33-.02 2.17-1.22 3.07-2.5.64-.93.9-1.4 1.4-2.46-3.25-1.21-3.77-5.85-.56-7.56-.98-1.38-2.43-2.2-3.14-2.2Z"
      fill="currentColor"
    />
  </svg>
{% endcapture %}

{% capture play_icon %}
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M4.76 3.19c-.34.36-.56.9-.56 1.61v14.4c0 .71.22 1.25.56 1.61l.09.08 8.06-8.06v-.66L4.85 3.11l-.09.08Z" fill="currentColor" opacity=".65"/>
    <path d="M15.59 14.93 12.91 12l2.68-2.93.06.03 3.18 1.81c.91.52.91 1.36 0 1.88l-3.18 1.81-.06.03Z" fill="currentColor"/>
    <path d="M15.65 14.9 12.91 12 4.76 20.11c.54.57 1.41.64 2.39.08l8.5-4.84" fill="currentColor" opacity=".8"/>
    <path d="M15.65 9.1 7.15 4.26c-.98-.56-1.85-.49-2.39.08L12.91 12l2.74-2.9Z" fill="currentColor" opacity=".5"/>
  </svg>
{% endcapture %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} app-download-widget color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="app-download-widget__shell">
    <div class="app-download-widget__content">
      <p class="app-download-widget__eyebrow">{{ 'app_download_widget.eyebrow' | t }}</p>
      <h2 class="app-download-widget__heading">{{ 'app_download_widget.heading' | t }}</h2>
      <p class="app-download-widget__description">{{ 'app_download_widget.description' | t }}</p>

      <div class="app-download-widget__actions">
        {% if section.settings.app_store_url != blank %}
          <a href="{{ section.settings.app_store_url }}" class="button app-download-widget__button" target="_blank" rel="noopener">
            <span class="app-download-widget__button-icon">{{ apple_icon }}</span>
            <span>{{ 'app_download_widget.app_store_label' | t }}</span>
          </a>
        {% else %}
          <span class="button app-download-widget__button" aria-disabled="true">
            <span class="app-download-widget__button-icon">{{ apple_icon }}</span>
            <span>{{ 'app_download_widget.app_store_label' | t }}</span>
          </span>
        {% endif %}

        {% if section.settings.google_play_url != blank %}
          <a href="{{ section.settings.google_play_url }}" class="button-secondary app-download-widget__button" target="_blank" rel="noopener">
            <span class="app-download-widget__button-icon">{{ play_icon }}</span>
            <span>{{ 'app_download_widget.google_play_label' | t }}</span>
          </a>
        {% else %}
          <span class="button-secondary app-download-widget__button" aria-disabled="true">
            <span class="app-download-widget__button-icon">{{ play_icon }}</span>
            <span>{{ 'app_download_widget.google_play_label' | t }}</span>
          </span>
        {% endif %}
      </div>
    </div>

    <div class="app-download-widget__image-wrap">
      {% if section.settings.mockup_image != blank %}
        {{
          section.settings.mockup_image
          | image_url: width: 1400
          | image_tag:
            widths: '480, 720, 960, 1200, 1400',
            sizes: '(min-width: 990px) 42vw, 100vw',
            class: 'app-download-widget__image',
            alt: section.settings.mockup_image.alt
        }}
      {% else %}
        <img
          src="{{ section.settings.mockup_image_url | default: fallback_mockup_url }}"
          alt="{{ 'app_download_widget.heading' | t | escape }}"
          class="app-download-widget__image"
          loading="lazy"
        >
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .app-download-widget {
    position: relative;
  }

  .app-download-widget__shell {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 2rem;
    align-items: center;
    padding: clamp(1.5rem, 2vw, 2rem);
    border: 1px solid rgb(var(--color-border-rgb) / 0.8);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgb(126 181 71 / 0.18), transparent 28%),
      radial-gradient(circle at bottom right, rgb(242 176 57 / 0.18), transparent 24%),
      linear-gradient(145deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 0.88));
    box-shadow: 0 24px 80px rgb(19 31 15 / 0.08);
  }

  @media screen and (min-width: 990px) {
    .app-download-widget__shell {
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      padding: clamp(2rem, 4vw, 3.5rem);
    }
  }

  .app-download-widget__content {
    display: grid;
    gap: 1rem;
    max-width: 40rem;
  }

  .app-download-widget__eyebrow {
    margin: 0;
    color: var(--color-foreground-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
  }

  .app-download-widget__heading {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 5vw, 3.9rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .app-download-widget__description {
    margin: 0;
    max-width: 46ch;
    color: var(--color-foreground-muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .app-download-widget__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }

  .app-download-widget__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-width: min(100%, 17rem);
  }

  .app-download-widget__button-icon {
    display: inline-flex;
    width: 1.25rem;
    height: 1.25rem;
    flex: 0 0 auto;
  }

  .app-download-widget__button-icon svg {
    width: 100%;
    height: 100%;
  }

  .app-download-widget__image-wrap {
    position: relative;
    display: block;
    border-radius: 1.6rem;
    overflow: hidden;
    box-shadow: 0 24px 70px rgb(18 28 13 / 0.16);
  }

  .app-download-widget__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .app-download-widget__image-wrap {
      border-radius: 1.2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "App download widget",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "url",
      "id": "app_store_url",
      "label": "App Store URL"
    },
    {
      "type": "url",
      "id": "google_play_url",
      "label": "Google Play URL"
    },
    {
      "type": "image_picker",
      "id": "mockup_image",
      "label": "Phone mockup image"
    },
    {
      "type": "url",
      "id": "mockup_image_url",
      "label": "External mockup image URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "App download widget",
      "category": "Text"
    }
  ]
}
{% endschema %}
