{% liquid
  assign fallback_mockup_url = 'https://cdn.shopify.com/s/files/1/0969/4124/4803/files/WhatsApp_Image_2026-03-11_at_16.33.34.jpg?v=1773246897'
%}

{% capture apple_icon %}
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path
      d="M15.08 4.03c.82-1 1.37-2.38 1.22-3.76-1.19.05-2.63.8-3.48 1.8-.76.88-1.43 2.28-1.25 3.62 1.32.1 2.66-.67 3.51-1.66Zm1.2 2.01c-1.92 0-2.73 1.15-4.06 1.15-1.37 0-1.73-1.08-3.79-1.08-2.03 0-4.19 1.74-4.19 5.02 0 2.18.86 4.54 1.91 6.03.9 1.27 1.68 2.68 2.96 2.63 1.23-.05 1.7-.79 3.19-.79 1.5 0 1.92.79 3.21.76 1.33-.02 2.17-1.22 3.07-2.5.64-.93.9-1.4 1.4-2.46-3.25-1.21-3.77-5.85-.56-7.56-.98-1.38-2.43-2.2-3.14-2.2Z"
      fill="currentColor"
    />
  </svg>
{% endcapture %}

{% capture play_icon %}
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M4.76 3.19c-.34.36-.56.9-.56 1.61v14.4c0 .71.22 1.25.56 1.61l.09.08 8.06-8.06v-.66L4.85 3.11l-.09.08Z" fill="currentColor" opacity=".65"/>
    <path d="M15.59 14.93 12.91 12l2.68-2.93.06.03 3.18 1.81c.91.52.91 1.36 0 1.88l-3.18 1.81-.06.03Z" fill="currentColor"/>
    <path d="M15.65 14.9 12.91 12 4.76 20.11c.54.57 1.41.64 2.39.08l8.5-4.84" fill="currentColor" opacity=".8"/>
    <path d="M15.65 9.1 7.15 4.26c-.98-.56-1.85-.49-2.39.08L12.91 12l2.74-2.9Z" fill="currentColor" opacity=".5"/>
  </svg>
{% endcapture %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} app-download-widget color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="app-download-widget__shell">
    <div class="app-download-widget__content">
      <p class="app-download-widget__eyebrow">{{ 'app_download_widget.eyebrow' | t }}</p>
      <h2 class="app-download-widget__heading">{{ 'app_download_widget.heading' | t }}</h2>
      <p class="app-download-widget__description">{{ 'app_download_widget.description' | t }}</p>

      <div class="app-download-widget__actions">
        {% if section.settings.app_store_url != blank %}
          <a href="{{ section.settings.app_store_url }}" class="button app-download-widget__button" target="_blank" rel="noopener">
            <span class="app-download-widget__button-icon">{{ apple_icon }}</span>
            <span>{{ 'app_download_widget.app_store_label' | t }}</span>
          </a>
        {% else %}
          <span class="button app-download-widget__button" aria-disabled="true">
            <span class="app-download-widget__button-icon">{{ apple_icon }}</span>
            <span>{{ 'app_download_widget.app_store_label' | t }}</span>
          </span>
        {% endif %}

        {% if section.settings.google_play_url != blank %}
          <a href="{{ section.settings.google_play_url }}" class="button-secondary app-download-widget__button" target="_blank" rel="noopener">
            <span class="app-download-widget__button-icon">{{ play_icon }}</span>
            <span>{{ 'app_download_widget.google_play_label' | t }}</span>
          </a>
        {% else %}
          <span class="button-secondary app-download-widget__button" aria-disabled="true">
            <span class="app-download-widget__button-icon">{{ play_icon }}</span>
            <span>{{ 'app_download_widget.google_play_label' | t }}</span>
          </span>
        {% endif %}
      </div>
    </div>

    <div class="app-download-widget__mockup-wrap">
      <div class="app-download-widget__halo app-download-widget__halo--one"></div>
      <div class="app-download-widget__halo app-download-widget__halo--two"></div>
      <div class="app-download-widget__phone">
        <div class="app-download-widget__phone-notch"></div>
        <div class="app-download-widget__screen">
          {% if section.settings.mockup_image != blank %}
            {{
              section.settings.mockup_image
              | image_url: width: 1200
              | image_tag:
                widths: '360, 480, 720, 960, 1200',
                sizes: '(min-width: 990px) 360px, 72vw',
                class: 'app-download-widget__screen-image',
                alt: section.settings.mockup_image.alt
            }}
          {% elsif section.settings.mockup_image_url != blank %}
            <img
              src="{{ section.settings.mockup_image_url }}"
              alt="{{ 'app_download_widget.heading' | t | escape }}"
              class="app-download-widget__screen-image"
              loading="lazy"
            >
          {% elsif fallback_mockup_url != blank %}
            <img
              src="{{ fallback_mockup_url }}"
              alt="{{ 'app_download_widget.heading' | t | escape }}"
              class="app-download-widget__screen-image"
              loading="lazy"
            >
          {% else %}
            <div class="app-download-widget__screen-ui">
              <div class="app-download-widget__screen-top">
                <div>
                  <p class="app-download-widget__screen-kicker">{{ 'app_download_widget.mockup_kicker' | t }}</p>
                  <p class="app-download-widget__screen-title">{{ 'app_download_widget.mockup_title' | t }}</p>
                </div>
                <span class="app-download-widget__screen-badge">{{ 'app_download_widget.mockup_badge' | t }}</span>
              </div>
              <div class="app-download-widget__screen-card app-download-widget__screen-card--feature">
                <div class="app-download-widget__sprout"></div>
                <div class="app-download-widget__screen-copy">
                  <p>{{ 'app_download_widget.feature_title' | t }}</p>
                  <span>{{ 'app_download_widget.feature_text' | t }}</span>
                </div>
              </div>
              <div class="app-download-widget__screen-card app-download-widget__screen-card--stats">
                <div class="app-download-widget__stat">
                  <span></span>
                  <small>{{ 'app_download_widget.stat_one' | t }}</small>
                </div>
                <div class="app-download-widget__stat">
                  <span></span>
                  <small>{{ 'app_download_widget.stat_two' | t }}</small>
                </div>
                <div class="app-download-widget__stat">
                  <span></span>
                  <small>{{ 'app_download_widget.stat_three' | t }}</small>
                </div>
              </div>
              <div class="app-download-widget__screen-card app-download-widget__screen-card--footer">
                <div class="app-download-widget__pill"></div>
                <div class="app-download-widget__pill app-download-widget__pill--short"></div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .app-download-widget {
    position: relative;
  }

  .app-download-widget__shell {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 2rem;
    align-items: center;
    padding: clamp(1.5rem, 2vw, 2rem);
    border: 1px solid rgb(var(--color-border-rgb) / 0.8);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgb(126 181 71 / 0.18), transparent 28%),
      radial-gradient(circle at bottom right, rgb(242 176 57 / 0.18), transparent 24%),
      linear-gradient(145deg, rgb(var(--color-background-rgb) / 0.98), rgb(var(--color-background-rgb) / 0.88));
    box-shadow: 0 24px 80px rgb(19 31 15 / 0.08);
  }

  @media screen and (min-width: 990px) {
    .app-download-widget__shell {
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      padding: clamp(2rem, 4vw, 3.5rem);
    }
  }

  .app-download-widget__content {
    display: grid;
    gap: 1rem;
    max-width: 40rem;
  }

  .app-download-widget__eyebrow {
    margin: 0;
    color: var(--color-foreground-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
  }

  .app-download-widget__heading {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 5vw, 3.9rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .app-download-widget__description {
    margin: 0;
    max-width: 46ch;
    color: var(--color-foreground-muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .app-download-widget__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }

  .app-download-widget__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-width: min(100%, 17rem);
  }

  .app-download-widget__button-icon {
    display: inline-flex;
    width: 1.25rem;
    height: 1.25rem;
    flex: 0 0 auto;
  }

  .app-download-widget__button-icon svg {
    width: 100%;
    height: 100%;
  }

  .app-download-widget__mockup-wrap {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 28rem;
  }

  .app-download-widget__halo {
    position: absolute;
    border-radius: 999px;
    filter: blur(4px);
    opacity: 0.85;
  }

  .app-download-widget__halo--one {
    width: 12rem;
    height: 12rem;
    top: 8%;
    right: 10%;
    background: radial-gradient(circle, rgb(120 177 70 / 0.42), transparent 70%);
  }

  .app-download-widget__halo--two {
    width: 15rem;
    height: 15rem;
    bottom: 0;
    left: 0;
    background: radial-gradient(circle, rgb(242 176 57 / 0.3), transparent 72%);
  }

  .app-download-widget__phone {
    position: relative;
    width: min(100%, 22rem);
    aspect-ratio: 0.53;
    padding: 0.7rem;
    border-radius: 2.6rem;
    background:
      linear-gradient(160deg, rgb(24 29 25), rgb(9 11 10)),
      linear-gradient(160deg, rgb(255 255 255 / 0.35), transparent);
    box-shadow:
      0 28px 80px rgb(6 14 8 / 0.3),
      inset 0 0 0 1px rgb(255 255 255 / 0.12);
  }

  .app-download-widget__phone::before {
    content: '';
    position: absolute;
    inset: 0.35rem;
    border-radius: 2.25rem;
    border: 1px solid rgb(255 255 255 / 0.08);
    pointer-events: none;
  }

  .app-download-widget__phone-notch {
    position: absolute;
    top: 0.95rem;
    left: 50%;
    transform: translateX(-50%);
    width: 36%;
    height: 1.45rem;
    border-radius: 999px;
    background: rgb(7 9 8);
    z-index: 2;
  }

  .app-download-widget__screen {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgb(126 181 71 / 0.34), transparent 28%),
      linear-gradient(180deg, #122116 0%, #0d1710 36%, #f3eedf 36%, #faf6ec 100%);
  }

  .app-download-widget__screen-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .app-download-widget__screen-ui {
    height: 100%;
    display: grid;
    grid-template-rows: auto auto auto 1fr;
    gap: 0.85rem;
    padding: 3.5rem 1rem 1rem;
  }

  .app-download-widget__screen-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .app-download-widget__screen-kicker,
  .app-download-widget__screen-title,
  .app-download-widget__screen-copy p,
  .app-download-widget__screen-copy span {
    margin: 0;
  }

  .app-download-widget__screen-kicker {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgb(255 255 255 / 0.72);
  }

  .app-download-widget__screen-title {
    margin-top: 0.35rem;
    color: #fffdf8;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.05;
  }

  .app-download-widget__screen-badge {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.12);
    color: #fffdf8;
    font-size: 0.7rem;
    backdrop-filter: blur(12px);
  }

  .app-download-widget__screen-card {
    border-radius: 1.35rem;
    background: rgb(255 255 255 / 0.72);
    box-shadow: 0 10px 30px rgb(24 35 18 / 0.08);
  }

  .app-download-widget__screen-card--feature {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    align-items: center;
    padding: 0.95rem;
  }

  .app-download-widget__sprout {
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    background:
      radial-gradient(circle at 30% 30%, rgb(255 255 255 / 0.9), transparent 30%),
      linear-gradient(160deg, #86b45a, #4e7d38);
    position: relative;
  }

  .app-download-widget__sprout::before,
  .app-download-widget__sprout::after {
    content: '';
    position: absolute;
    background: #eef8db;
    border-radius: 100% 0 100% 0;
  }

  .app-download-widget__sprout::before {
    width: 0.8rem;
    height: 1.2rem;
    top: 0.7rem;
    left: 1rem;
    transform: rotate(-26deg);
  }

  .app-download-widget__sprout::after {
    width: 0.7rem;
    height: 1rem;
    top: 0.95rem;
    left: 1.45rem;
    transform: rotate(24deg);
  }

  .app-download-widget__screen-copy p {
    font-size: 0.9rem;
    font-weight: 700;
    color: #17301a;
  }

  .app-download-widget__screen-copy span {
    display: block;
    margin-top: 0.18rem;
    font-size: 0.74rem;
    color: rgb(23 48 26 / 0.72);
    line-height: 1.45;
  }

  .app-download-widget__screen-card--stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
    padding: 0.8rem;
  }

  .app-download-widget__stat {
    display: grid;
    gap: 0.5rem;
    align-items: end;
  }

  .app-download-widget__stat span {
    display: block;
    min-height: 2.3rem;
    border-radius: 999px 999px 0.85rem 0.85rem;
    background: linear-gradient(180deg, #7bb14a, #dbefbf);
  }

  .app-download-widget__stat:nth-child(2) span {
    min-height: 3.1rem;
  }

  .app-download-widget__stat:nth-child(3) span {
    min-height: 1.7rem;
    background: linear-gradient(180deg, #f2b039, #f7dfac);
  }

  .app-download-widget__stat small {
    font-size: 0.68rem;
    color: rgb(23 48 26 / 0.72);
  }

  .app-download-widget__screen-card--footer {
    display: grid;
    gap: 0.65rem;
    padding: 0.9rem;
    align-content: start;
  }

  .app-download-widget__pill {
    height: 0.85rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgb(74 122 56 / 0.14), rgb(74 122 56 / 0.04));
  }

  .app-download-widget__pill--short {
    width: 58%;
  }

  @media screen and (max-width: 749px) {
    .app-download-widget__phone {
      width: min(100%, 18rem);
    }

    .app-download-widget__mockup-wrap {
      min-height: 24rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "App download widget",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "url",
      "id": "app_store_url",
      "label": "App Store URL"
    },
    {
      "type": "url",
      "id": "google_play_url",
      "label": "Google Play URL"
    },
    {
      "type": "image_picker",
      "id": "mockup_image",
      "label": "Phone mockup image"
    },
    {
      "type": "url",
      "id": "mockup_image_url",
      "label": "External mockup image URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "App download widget",
      "category": "Text"
    }
  ]
}
{% endschema %}
