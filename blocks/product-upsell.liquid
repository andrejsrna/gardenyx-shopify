{% liquid
  assign block_settings = block.settings
  assign upsell_product = closest.product.metafields.custom.upsell_product.value | default: block_settings.product

  if request.visual_preview_mode and upsell_product == blank
    assign upsell_product = collections.all.products.first
  endif

  assign heading = block_settings.heading | strip
  if heading == blank
    assign heading = 'product_upsell.heading' | t
  endif

  if upsell_product != blank
    assign upsell_variant = upsell_product.selected_or_first_available_variant
    assign upsell_url = upsell_variant.url | default: upsell_product.url
    assign upsell_image_alt = upsell_product.featured_media.alt | default: upsell_product.title
  endif
%}

{%- if upsell_product != blank or request.design_mode -%}
  <div
    class="product-upsell-block spacing-style"
    style="{% render 'spacing-style', settings: block_settings %}"
    {{ block.shopify_attributes }}
  >
    <p class="product-upsell-block__heading">{{ heading }}</p>

    {% if upsell_product != blank %}
      <a href="{{ upsell_url }}" class="product-upsell-block__card">
        <div class="product-upsell-block__media">
          {% if upsell_product.featured_media != blank %}
            {{
              upsell_product.featured_media
              | image_url: width: 240
              | image_tag:
                widths: '120, 180, 240',
                sizes: '72px',
                class: 'product-upsell-block__image',
                alt: upsell_image_alt
            }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'product-upsell-block__image product-upsell-block__image--placeholder' }}
          {% endif %}
        </div>

        <div class="product-upsell-block__content">
          <p class="product-upsell-block__title">{{ upsell_product.title }}</p>
          <div class="product-upsell-block__price">
            {% render 'price', product_resource: upsell_product, show_unit_price: true %}
          </div>
        </div>
      </a>
    {% else %}
      <div class="product-upsell-block__placeholder">
        {{ 'product_upsell.empty' | t }}
      </div>
    {% endif %}
  </div>
{%- endif -%}

{% stylesheet %}
  .product-upsell-block {
    width: 100%;
  }

  .product-upsell-block__heading {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .product-upsell-block__card {
    display: grid;
    grid-template-columns: 4.5rem minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
    padding: 0.75rem;
    border: 1px solid rgb(var(--color-border-rgb) / 0.8);
    border-radius: 1rem;
    background: rgb(var(--color-background-rgb) / 0.92);
    text-decoration: none;
    color: inherit;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .product-upsell-block__card:hover,
  .product-upsell-block__card:focus-visible {
    transform: translateY(-1px);
    border-color: rgb(var(--color-foreground-rgb) / 0.18);
    box-shadow: 0 12px 30px rgb(19 31 15 / 0.08);
  }

  .product-upsell-block__media {
    overflow: hidden;
    border-radius: 0.85rem;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    aspect-ratio: 1;
  }

  .product-upsell-block__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-upsell-block__image--placeholder {
    padding: 0.75rem;
  }

  .product-upsell-block__content {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .product-upsell-block__title {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.35;
    text-wrap: pretty;
  }

  .product-upsell-block__price {
    font-size: 0.92rem;
  }

  .product-upsell-block__price .compare-at-price {
    opacity: 0.55;
    margin-right: 0.35rem;
  }

  .product-upsell-block__placeholder {
    padding: 0.85rem 1rem;
    border: 1px dashed rgb(var(--color-border-rgb) / 0.75);
    border-radius: 1rem;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: 0.95rem;
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Upsell",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Uses the product metafield custom.upsell_product when available. The product picker below is a template-wide fallback."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Fallback product"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Upsell"
    }
  ]
}
{% endschema %}
